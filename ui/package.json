{
  "name": "ghrm-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && node scripts/check.js pack",
    "build:check": "vite build --outDir .vite-check && node scripts/check.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "happy-dom": "20.9.0",
    "typescript": "5.8.3",
    "vite": "6.4.2",
    "vitest": "3.2.2"
  }
}
