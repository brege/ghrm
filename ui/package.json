{
  "name": "ghrm-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=11.10.0"
  },
  "scripts": {
    "build": "vite build && node scripts/check.js pack",
    "build:check": "vite build --outDir .vite-check && node scripts/check.js source",
    "icons:check": "node scripts/icons.js check",
    "icons:write": "node scripts/icons.js write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lit": "3.3.3"
  },
  "devDependencies": {
    "@types/react": "19.2.6",
    "happy-dom": "20.9.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-icons": "5.6.0",
    "typescript": "5.8.3",
    "vite": "6.4.2",
    "vitest": "3.2.2"
  }
}
